<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    
    <!-- Material themes -->
    <style name="MyMaterialTheme" parent="MyMaterialTheme.Base" />
    <style name="MyMaterialTheme.Dark" parent="MyMaterialTheme.Base.Dark" />
    
    <style name="MyMaterialTheme.Base" parent="Theme.MaterialComponents.Light">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowBackground">@color/windowBackground</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>
    
    <style name="MyMaterialTheme.Base.Dark" parent="Theme.MaterialComponents">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowBackground">@color/windowBackgroundDark</item>
        <item name="colorPrimary">@color/colorPrimaryDark</item>
        <item name="colorPrimaryDark">@color/colorPrimary</item>
        <item name="colorAccent">@color/colorAccentDark</item>
    </style>
    
    <!-- Dialog themes -->
    <style name="DialogTheme" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    
    <style name="DialogTheme.Dark" parent="Theme.MaterialComponents.Dialog">
        <item name="colorPrimary">@color/colorPrimaryDark</item>
        <item name="colorPrimaryDark">@color/colorPrimary</item>
        <item name="colorAccent">@color/colorAccentDark</item>
    </style>
    
    <!-- Alert themes -->
    <style name="AlertTheme" parent="Theme.MaterialComponents.Light.Dialog.Alert">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    
    <style name="AlertTheme.Dark" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="colorPrimary">@color/colorPrimaryDark</item>
        <item name="colorPrimaryDark">@color/colorPrimary</item>
        <item name="colorAccent">@color/colorAccentDark</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textColorPrimary">@android:color/white</item>
        <item name="android:textColorSecondary">@android:color/white</item>
        <item name="buttonBarButtonStyle">@style/AlertButtonStyle.Dark</item>
        <item name="materialButtonStyle">@style/AlertButtonStyle.Dark</item>
        <item name="android:windowBackground">@color/windowBackgroundDark</item>
        <item name="android:colorBackground">@color/windowBackgroundDark</item>
        <item name="android:background">@color/windowBackgroundDark</item>
    </style>

    
    <style name="AlertButtonStyle.Dark" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">16sp</item>
    </style>


    
    <!-- Bottom sheet dialog themes -->
    <style name="BottomSheetDialogTheme" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>
    
    <style name="BottomSheetDialogTheme.Dark" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="colorPrimary">@color/colorPrimaryDark</item>
        <item name="colorPrimaryDark">@color/colorPrimary</item>
        <item name="colorAccent">@color/colorAccentDark</item>
        <item name="colorOnSurface">@android:color/white</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textColorPrimary">@android:color/white</item>
        <item name="android:textColorSecondary">@android:color/white</item>
    </style>
    
    <!-- Menu text appearance -->
    <style name="MenuTextAppearance" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textSize">16sp</item>
    </style>
    
    <style name="MenuTextAppearance.Dark" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@android:color/white</item>
    </style>
    
    <!-- Snackbar button styles -->
    <style name="SnackBarButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/colorAccent</item>
    </style>
    
    <style name="SnackBarButtonDark" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/colorAccentDark</item>
    </style>
    
    <!-- Custom spinner dropdown style -->
    <style name="CustomSpinnerDropDown" parent="Widget.AppCompat.ListView.DropDown">
        <item name="android:scrollbarSize">16dp</item>
        <item name="android:scrollbarThumbVertical">@drawable/custom_scrollbar</item>
        <item name="android:scrollbarTrackVertical">@android:color/transparent</item>
        <item name="android:scrollbarStyle">outsideOverlay</item>
    </style>
    
    <!-- Custom spinner style -->
    <style name="CustomSpinner" parent="Widget.AppCompat.Spinner">
        <item name="android:dropDownListViewStyle">@style/CustomSpinnerDropDown</item>
    </style>
    
    <!-- Progress bar styles -->
    <style name="ProgressBarCircle" parent="Widget.AppCompat.ProgressBar">
        <item name="android:indeterminateDrawable">@drawable/progress_circle</item>
    </style>
    
    <!-- Icon button style -->
    <style name="IconButton" parent="Widget.AppCompat.Button">
        <item name="android:minWidth">48dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:padding">8dp</item>
    </style>
</resources>